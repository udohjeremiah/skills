{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./tsconfig.react.json",
  "compilerOptions": {
    "incremental": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "plugins": [{ "name": "next" }],
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
